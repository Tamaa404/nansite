---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const allUpdates = (await getCollection('updates'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryColors: Record<string, { bg: string; text: string }> = {
  'AI': { bg: 'bg-purple-900/50', text: 'text-purple-300' },
  'Teaching': { bg: 'bg-blue-900/50', text: 'text-blue-300' },
  'Personal': { bg: 'bg-pink-900/50', text: 'text-pink-300' },
  'Robotics': { bg: 'bg-orange-900/50', text: 'text-orange-300' },
  'Web Dev': { bg: 'bg-cyan-900/50', text: 'text-cyan-300' },
};
---

<MainLayout>
  <div class="max-w-4xl mx-auto px-4 py-20">
    <div class="mb-16">
      <h1 class="text-4xl font-bold mb-4">The Feed</h1>
      <p class="text-lg text-slate-300">
        Quick updates, discoveries, and thoughts. Life in chronological order.
      </p>
    </div>

    {allUpdates.length > 0 ? (
      <div class="space-y-4">
        {allUpdates.map((update) => {
          const colors = categoryColors[update.data.category] || { bg: 'bg-slate-700', text: 'text-slate-300' };
          return (
            <a 
              href={`/feed/${update.id}`}
              class="block bg-slate-800/50 border border-slate-700 rounded-lg p-6 hover:border-cyan-400 hover:bg-slate-800 transition-all group"
            >
              <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    <h3 class="font-bold text-lg group-hover:text-cyan-400 transition-colors">
                      {update.data.title}
                    </h3>
                    <span class={`text-xs font-semibold px-3 py-1 rounded-full ${colors.bg} ${colors.text} whitespace-nowrap`}>
                      #{update.data.category}
                    </span>
                  </div>
                  <p class="text-slate-400 text-sm mb-4">{update.data.description}</p>
                  <p class="text-xs text-slate-500">
                    {update.data.date.toLocaleDateString('en-US', { 
                      year: 'numeric', 
                      month: 'long', 
                      day: 'numeric' 
                    })}
                  </p>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-12 text-center">
        <p class="text-slate-400 mb-4">No updates yet. Check back soon!</p>
        <p class="text-sm text-slate-500">Life updates will appear here in reverse chronological order.</p>
      </div>
    )}
  </div>
</MainLayout>
