---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { ExternalLink } from 'lucide-astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project }
  }));
}

interface Props {
  project: any;
}

const { project } = Astro.props;
---

<MainLayout>
  <article class="max-w-3xl mx-auto px-4 py-20">
    <header class="mb-12">
      <div class="mb-4">
        <a href="/lab" class="text-cyan-400 hover:text-cyan-300 transition-colors">← Back to Lab</a>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">{project.data.title}</h1>
      <p class="text-lg text-slate-300 mb-6">{project.data.description}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        {project.data.tags.map((tag: string) => (
          <span class="text-sm bg-slate-700 px-3 py-1 rounded-full text-slate-300">
            {tag}
          </span>
        ))}
      </div>
      {project.data.link && (
        <a 
          href={project.data.link} 
          target="_blank" 
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-600 hover:bg-cyan-700 rounded-lg font-semibold transition-colors"
        >
          Visit Project <ExternalLink size={16} />
        </a>
      )}
    </header>

    <div class="prose prose-invert max-w-none">
      <p class="text-slate-300 text-lg leading-relaxed">
        {project.data.description}
      </p>
      <p class="text-slate-400 text-sm mt-8">
        🔍 Full project details coming soon. Visit the project link above to learn more.
      </p>
    </div>

    <footer class="mt-16 pt-8 border-t border-slate-700">
      <a href="/lab" class="text-cyan-400 hover:text-cyan-300 transition-colors font-semibold">
        ← Back to Lab
      </a>
    </footer>
  </article>
</MainLayout>
