---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { ExternalLink } from 'lucide-astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featuredProjects = projects.filter(p => p.data.featured);
const otherProjects = projects.filter(p => !p.data.featured);
---

<MainLayout>
  <div class="max-w-4xl mx-auto px-4 py-20">
    <div class="mb-16">
      <h1 class="text-4xl font-bold mb-4">The Lab</h1>
      <p class="text-lg text-slate-300">
        A collection of projects spanning AI, robotics, and web development. Each one represents a journey of learning and iteration.
      </p>
    </div>

    {featuredProjects.length > 0 && (
      <div class="mb-20">
        <h2 class="text-2xl font-bold text-cyan-400 mb-8">Featured Projects</h2>
        <div class="space-y-6">
          {featuredProjects.map((project) => (
            <div class="bg-slate-800/50 border border-cyan-900/50 rounded-lg p-8 hover:border-cyan-400 transition-all">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                  <a href={`/lab/${project.id}`} class="hover:text-cyan-400 transition-colors">
                    <h3 class="text-2xl font-bold mb-2">{project.data.title}</h3>
                  </a>
                  <p class="text-slate-300">{project.data.description}</p>
                </div>
                {project.data.link && (
                  <a 
                    href={project.data.link} 
                    target="_blank" 
                    rel="noopener"
                    class="flex-shrink-0 p-2 text-cyan-400 hover:bg-slate-700 rounded transition-colors"
                  >
                    <ExternalLink size={24} />
                  </a>
                )}
              </div>
              <div class="flex flex-wrap gap-2">
                {project.data.tags.map((tag) => (
                  <span class="text-xs bg-slate-700 px-3 py-1 rounded-full text-slate-300">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {otherProjects.length > 0 && (
      <div>
        <h2 class="text-2xl font-bold text-cyan-400 mb-8">
          {featuredProjects.length > 0 ? 'Other Projects' : 'All Projects'}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {otherProjects.map((project) => (
            <div class="relative bg-slate-800/50 border border-slate-700 rounded-lg p-6 hover:border-cyan-400 transition-all group">
              <a href={`/lab/${project.id}`} class="absolute inset-0 z-10"></a>
              <h3 class="font-bold text-lg mb-2 group-hover:text-cyan-400 transition-colors">
                {project.data.title}
              </h3>
              <p class="text-slate-400 text-sm mb-4">{project.data.description}</p>
              <div class="flex flex-wrap gap-2 mb-4 relative z-20">
                {project.data.tags.map((tag) => (
                  <span class="text-xs bg-slate-700 px-2 py-1 rounded text-slate-300">
                    {tag}
                  </span>
                ))}
              </div>
              {project.data.link && (
                <a 
                  href={project.data.link} 
                  target="_blank" 
                  rel="noopener"
                  class="relative z-20 text-cyan-400 hover:text-cyan-300 text-sm font-semibold flex items-center gap-1 transition-colors"
                >
                  View External <ExternalLink size={14} />
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    {projects.length === 0 && (
      <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-12 text-center">
        <p class="text-slate-400 mb-4">No projects yet. Check back soon!</p>
        <p class="text-sm text-slate-500">Projects appear here as they're added to the collection.</p>
      </div>
    )}
  </div>
</MainLayout>
